{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://newshub-kodq.onrender.com/api/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "https://newshub-kodq.onrender.com/static/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
